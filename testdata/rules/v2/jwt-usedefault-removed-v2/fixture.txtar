-- input/main.go --
package example

import (
	"github.com/lestrrat-go/jwx/v2/jwk"
	"github.com/lestrrat-go/jwx/v2/jwt"
)

func parseDefault(data []byte, set jwk.Set) (jwt.Token, error) {
	return jwt.Parse(data, jwt.WithKeySet(set), jwt.UseDefault(true))
}
