-- want_fix/main.go --
package example

import (
	"fmt"

	"github.com/lestrrat-go/jwx/v4/jwk"
	"github.com/lestrrat-go/jwx/v4/jwt"
)

// v2 accessor methods returned T; v4 returns (T, bool). The rule matches
// every convenience-accessor name; realistic v2 code calls several of
// them on a Token or Key.

func describe(tok jwt.Token, key jwk.Key) {
	fmt.Println(tok.Subject())
	fmt.Println(tok.Expiration())
	fmt.Println(tok.IssuedAt())
	fmt.Println(key.Algorithm())
	fmt.Println(key.KeyID())
}
