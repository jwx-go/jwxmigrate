-- want_fix/main.go --
package example

import (
	"errors"
	"fmt"

	"github.com/lestrrat-go/jwx/v4/jwt"
)

func check(tok jwt.Token) error {
	if err := jwt.Validate(tok); err != nil {
		if errors.Is(err, jwt.TokenExpiredError()) {
			return fmt.Errorf("expired: %w", err)
		}
		if errors.Is(err, jwt.InvalidIssuerError()) {
			return fmt.Errorf("wrong issuer: %w", err)
		}
		if errors.Is(err, jwt.InvalidAudienceError()) {
			return fmt.Errorf("wrong audience: %w", err)
		}
		return err
	}
	return nil
}

func parse(data []byte) error {
	_, err := jwt.Parse(data)
	if errors.Is(err, jwt.ParseError()) {
		return fmt.Errorf("parse failed: %w", err)
	}
	return err
}
