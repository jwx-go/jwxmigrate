-- want_fix/main.go --
package example

import (
	"errors"
	"fmt"

	"github.com/lestrrat-go/jwx/v4/jwt"
)

func lookup(tok jwt.Token) error {
	var sub string
	if err := tok.Get("sub", &sub); err != nil {
		if errors.Is(err, jwt.ClaimNotFoundError()) {
			return fmt.Errorf("no sub claim")
		}
		if errors.Is(err, jwt.ClaimAssignmentFailedError()) {
			return fmt.Errorf("sub wrong type: %w", err)
		}
		return err
	}
	return nil
}
